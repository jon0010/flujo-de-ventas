{
  "name": "flujo-de-ventas-ceo-digital",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "bash ./scripts/dev-full.sh",
    "dev:full:stop": "fuser -k 3001/tcp 5173/tcp || true",
    "server": "json-server server/db.json --port 3001",
    "dev:all": "concurrently -n server,web -c blue,green \"npm run server\" \"npm run dev\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.2",
    "mongodb": "^6.17.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sonner": "^2.0.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "json-server": "^0.17.4",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "vercel": "^54.5.0",
    "vite": "^8.0.0"
  }
}
